# =================================================================
# RateHonk CRM - Production Environment Configuration
# =================================================================

# Database Configuration (REQUIRED)
# Use Neon PostgreSQL or your own PostgreSQL database
DATABASE_URL=postgresql://username:password@host:port/database?ssl=true

# Security Configuration (REQUIRED)
# Generate secure random strings (at least 32 characters each)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
SESSION_SECRET=your-super-secret-session-key-at-least-32-characters-long

# AI Features (OPTIONAL)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Email Services (OPTIONAL)
# SendGrid: Get from https://sendgrid.com/
SENDGRID_API_KEY=your-sendgrid-api-key

# Custom SMTP (Alternative to SendGrid)
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# WhatsApp Provider API (OPTIONAL)
# Base URL for WhatsApp CRM provider (e.g. https://api.example.com)
WHATSAPP_PROVIDER_API_BASE=https://api.example.com
# Redirect path after crm-login (default /chat) - ensure this route exists on the provider app
# WHATSAPP_PANEL_REDIRECT_PATH=/chat

# Google Services (OPTIONAL)
# Get from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=your-google-redirect-uri

# =================================================================
# IMPORTANT NOTES:
# =================================================================
# 
# 1. Social Media Credentials (Facebook, Instagram, LinkedIn, etc.)
#    are NOT configured here. Each tenant configures their own
#    credentials through the UI in Settings > Social Integrations.
#
# 2. Only DATABASE_URL, JWT_SECRET, and SESSION_SECRET are required
#    for basic functionality.
#
# 3. All other variables are optional and can be configured later
#    through the tenant settings interface.
#
# 4. This file should be renamed to .env in production and kept secure.
# =================================================================