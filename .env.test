# Test Environment Configuration
NODE_ENV=test

# Database - Use the same Supabase instance but with test tenant isolation
DATABASE_URL=postgresql://postgres.ipepsanzqwbupegrkzwz:crm%402025@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# JWT Secret for testing
JWT_SECRET=test_jwt_secret_key_for_testing_only

# Email Configuration (use Ethereal for testing)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=test@ethereal.email
SMTP_PASSWORD=test_password

# Testing specific settings
ENABLE_CONSOLE_LOGGING=true
TEST_TIMEOUT=30000

# Disable external services during testing
DISABLE_EMAIL_SENDING=true
DISABLE_SMS_SENDING=true

# Test data configuration
TEST_TENANT_ID=999
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=password